doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    script.
      if (localStorage.getItem('kt_am_sidebar_collapsed') === '1') {
        document.documentElement.classList.add('sidebar-collapsed');
      }
    title= title ? title + ' — KT Telematic Asset Management' : 'KT Telematic Asset Management'
    link(rel="icon", type="image/png", href="/favicon.png")
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="stylesheet", href="https://cdn.datatables.net/1.13.11/css/dataTables.bootstrap5.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css")
    link(rel="stylesheet", href="/css/style.css")
  body
    if user
      .app-shell
        include partials/sidebar
        .app-main
          include partials/topbar
          main.app-content
            if messages && messages.length
              each message in messages
                .alert.alert-info(role="alert")= message
            if errors && errors.length
              each error in errors
                .alert.alert-danger(role="alert")= error
            block content
    else
      main
        if messages && messages.length
          each message in messages
            .alert.alert-info(role="alert")= message
        if errors && errors.length
          each error in errors
            .alert.alert-danger(role="alert")= error
        block content
    script(src="https://code.jquery.com/jquery-3.7.1.min.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="https://cdn.datatables.net/1.13.11/js/jquery.dataTables.min.js")
    script(src="https://cdn.datatables.net/1.13.11/js/dataTables.bootstrap5.min.js")
    if user
      script(src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js")
      script(src="/js/tour.js")
      script(src="/js/filter-pills.js")
      script(src="/js/sidebar.js")
    block scripts

