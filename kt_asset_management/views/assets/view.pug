extends ../layout

include ../mixins/page-header

block content
  +pageHeader(asset.assetCode, `${asset.make} ${asset.model}`)
    .detail-actions.d-flex.gap-2
      a.btn.btn-outline-secondary(href=`/assets/${asset.id}/history`)
        i.bi.bi-clock-history.me-1
        | History
      if asset.status === 'in_stock'
        a.btn.btn-outline-secondary(href=`/issue-asset?assetId=${asset.id}`)
          i.bi.bi-box-arrow-up.me-1
          | Issue
      if asset.status === 'issued'
        a.btn.btn-outline-secondary(href=`/return-asset?assetId=${asset.id}`)
          i.bi.bi-box-arrow-in-down.me-1
          | Return
      if asset.status !== 'scrapped'
        a.btn.btn-outline-secondary(href=`/scrap-asset?assetId=${asset.id}`)
          i.bi.bi-trash3.me-1
          | Scrap
      a.btn.btn-outline-secondary(href=`/assets/${asset.id}/edit`)
        i.bi.bi-pencil.me-1
        | Edit

  .table-surface(style="max-width: 640px; padding: 1.75rem;")
    .d-flex.gap-4.mb-4
      .photo-preview(style="width: 120px; height: 120px;")
        if asset.photoPath
          img(src=asset.photoPath, alt=asset.assetCode)
        else
          i.bi.bi-image
      div
        h5.mb-1= `${asset.make} ${asset.model}`
        p.text-muted.mb-2= asset.AssetCategory ? asset.AssetCategory.name : '—'
        span.status-badge(class=`status-${asset.status}`)= asset.status === 'in_stock' ? 'In Stock' : asset.status === 'issued' ? 'Issued' : 'Scrapped'

    dl.row.mb-0
      dt.col-sm-4.text-muted Asset ID
      dd.col-sm-8= asset.assetCode
      dt.col-sm-4.text-muted Serial Number
      dd.col-sm-8= asset.serialNumber
      dt.col-sm-4.text-muted Branch
      dd.col-sm-8= asset.branch
      dt.col-sm-4.text-muted Purchase Date
      dd.col-sm-8= asset.purchaseDate
      dt.col-sm-4.text-muted Purchase Value
      dd.col-sm-8= Number(asset.purchaseValue).toLocaleString(undefined, { style: 'currency', currency: 'INR' })
      if asset.currentHolder
        dt.col-sm-4.text-muted Issued To
        dd.col-sm-8
          a(href=`/employees/${asset.currentHolder.id}`)= asset.currentHolder.name
