extends ../layout

include ../mixins/page-header

block content
  +pageHeader(title)

  .table-surface(style="max-width: 640px; padding: 1.75rem;")
    form(method="POST", action=asset.id ? `/assets/${asset.id}?_method=PUT` : '/assets', enctype="multipart/form-data")
      .mb-4
        label.form-label Photo
        .photo-upload
          .photo-preview#photoPreview
            if asset.photoPath
              img(src=asset.photoPath, alt="Current photo")
            else
              i.bi.bi-image
          div
            input.form-control#photoInput(type="file", name="photo", accept="image/png,image/jpeg,image/webp,image/gif")
            p.form-text.text-muted.mb-0 JPEG, PNG, WEBP, or GIF. Max 5MB.

      .row
        .col-md-6.mb-3
          label.form-label(for="assetCode") Asset ID
          input.form-control#assetCode(type="text", name="assetCode", value=asset.assetCode, required, autofocus)
        .col-md-6.mb-3
          label.form-label(for="serialNumber") Serial Number
          input.form-control#serialNumber(type="text", name="serialNumber", value=asset.serialNumber, required)

      .row
        .col-md-6.mb-3
          label.form-label(for="categoryId") Category
          select.form-select#categoryId(name="categoryId", required)
            option(value="", disabled, selected=!asset.categoryId) Select a category
            each category in categories
              option(value=category.id, selected=String(asset.categoryId) === String(category.id))= category.name
        .col-md-6.mb-3
          label.form-label(for="branch") Branch
          input.form-control#branch(type="text", name="branch", value=asset.branch, required, placeholder="e.g. Chennai")

      .row
        .col-md-6.mb-3
          label.form-label(for="make") Make
          input.form-control#make(type="text", name="make", value=asset.make, required, placeholder="e.g. Dell")
        .col-md-6.mb-3
          label.form-label(for="model") Model
          input.form-control#model(type="text", name="model", value=asset.model, required, placeholder="e.g. Latitude 5440")

      .row
        .col-md-6.mb-3
          label.form-label(for="purchaseDate") Purchase Date
          input.form-control#purchaseDate(type="date", name="purchaseDate", value=asset.purchaseDate, required)
        .col-md-6.mb-3
          label.form-label(for="purchaseValue") Purchase Value
          input.form-control#purchaseValue(type="number", name="purchaseValue", value=asset.purchaseValue, step="0.01", min="0", required)

      button.btn.btn-primary(type="submit") Save
      a.btn.btn-link(href="/assets") Cancel

block scripts
  script.
    document.getElementById('photoInput').addEventListener('change', function (e) {
      var file = e.target.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function (ev) {
        document.getElementById('photoPreview').innerHTML = '<img src="' + ev.target.result + '" alt="Preview">';
      };
      reader.readAsDataURL(file);
    });
